#include <bits/stdc++.h>
using namespace std;

class SegmentTree {
public:
    vector<long long> tree, lazy;

    SegmentTree(vector<int> &nums) {
        int n = nums.size();
        tree.resize(4 * n);
        lazy.resize(4 * n);
        build(0, 0, n - 1, nums);
    }

    void build(int index, int l, int r, vector<int> &nums) {
        if (l == r) {
            tree[index] = nums[l];
            return;
        }

        int mid = (l + r) / 2;
        build(2 * index + 1, l, mid, nums);
        build(2 * index + 2, mid + 1, r, nums);

        tree[index] = tree[2 * index + 1] + tree[2 * index + 2];
    }

    void push(int index, int l, int r) {
        if (lazy[index] == 0) return;

        tree[index] += (r - l + 1) * lazy[index];

        if (l != r) {
            lazy[2 * index + 1] += lazy[index];
            lazy[2 * index + 2] += lazy[index];
        }

        lazy[index] = 0;
    }

    void update(int index, int l, int r, int ql, int qr, long long val) {
        push(index, l, r);

        if (l > qr || r < ql)
            return;

        if (ql <= l && r <= qr){
            lazy[index] += val;
            push(index, l, r);
            return;
        }

        int mid = (l + r) / 2;

        update(2 * index + 1, l, mid, ql, qr, val);
        update(2 * index + 2, mid + 1, r, ql, qr, val);

        tree[index] = tree[2 * index + 1] + tree[2 * index + 2];
    }

    long long query(int index, int l, int r, int ql, int qr) {
        push(index, l, r);

        if (l > qr || r < ql)
            return 0;

        if (ql <= l && r <= qr)
            return tree[index];

        int mid = (l + r)/2;

        return query(2 * index + 1, l, mid, ql, qr) + query(2 * index + 2, mid + 1, r, ql, qr);
    }
};

int main() {
    int n, q;
    cin >> n >> q;

    vector<int> nums(n);
    for (int i = 0; i < n; i++)
        cin >> nums[i];

    SegmentTree seg(nums);

    while (q--) {
        int type;
        cin >> type;

        if (type == 1){
            int l, r;
            long long val;
            cin >> l >> r >> val;
            seg.update(0, 0, n - 1, l - 1, r - 1, val);
        }
        else {
            int l;
            cin >> l ;
            cout << seg.query(0, 0, n - 1, l - 1, l - 1) << endl;
        }
    }
}
