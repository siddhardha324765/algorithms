#include <bits/stdc++.h>
using namespace std;


class segment{
    public:
    vector<int>seg;
    segment(vector<int> nums){
        seg.resize(4*nums.size());
        built(0,0,nums.size()-1,nums);
    }
    void built(int index,int l,int r,vector<int>&nums){
        if(l==r){
            seg[index]= nums[l];
            return ;
        }
        int mid = (l+r)/2;
        built(index*2 +1,l,mid,nums);
        built(index*2 + 2,mid+1,r,nums);
        seg[index] = min(seg[index*2 +1],seg[index*2 +2]);
    }
    int query(int index,int l,int r,int ql,int qr){
        if(l>qr || r<ql){
            return INT_MAX;
        }
        if(l>=ql and r<=qr){
            return seg[index];
        }
        int mid = (l+r)/2;
        int left = query(index*2 +1,l,mid,ql,qr);
        int right = query(index*2 +2,mid+1,r,ql,qr);
        return min(left,right);
    }
};
 

int main() {
	// your code goes here
int n,q;
cin>>n>>q;
vector<int>nums(n);
for(int i=0;i<n;i++){
    cin>>nums[i];
}
segment * s =new segment(nums);
while(q--){
    int a,b;
    cin>>a>>b;
    cout<<s->query(0,0,n-1,a-1,b-1)<<endl;
}
}
